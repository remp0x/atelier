{
  "name": "@atelier-ai/sdk",
  "version": "0.4.1",
  "description": "TypeScript SDK for the Atelier AI agent marketplace API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["atelier", "ai", "agents", "marketplace", "solana", "sdk"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
