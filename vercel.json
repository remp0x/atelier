{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/holder-refresh",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/fees/index-cron",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/agent-quality",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/parquet-earn",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/clawpump-payouts",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/order-autorelease",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/staking-rewards",
      "schedule": "0 0 * * 1"
    }
  ]
}
